# Market Buzz Kids — environment variables
#
# Copy this file to `.env` and fill in real values. `src/server.js` loads
# `.env` via dotenv at startup, so anything here is available as
# `process.env.FOO`. The `.env` file itself is gitignored.

# ── Phase 6.1: Neon Postgres ──────────────────────────────────────────────
# Get this from the Neon console → your project → Connection Details.
# Must include `?sslmode=require` for Neon.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Phase 6.2: Resend email ───────────────────────────────────────────────
# Get an API key from https://resend.com → API Keys.
# When missing, the app boots fine but emails are skipped (with a warning).
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender on Resend. For initial testing you can use Resend's
# sandbox sender 'onboarding@resend.dev' (also the default if unset).
# For production, verify your own domain in the Resend dashboard.
FROM_EMAIL=onboarding@resend.dev

# Shared secret for the cron endpoint POST /api/cron/send-digest.
# Pass it as `X-Cron-Secret: <value>` header. Generate with:
#   openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-string

# Base URL used to build absolute links in outgoing emails (verify link,
# consent link, "Read today's digest" button, /parent/delete-data link).
# Local dev: http://localhost:3199
# Prod:      https://yourdomain.com
APP_BASE_URL=http://localhost:3199

# ── Phase 7: Kid auth ─────────────────────────────────────────────────────
# Secret used to sign the `mbk_session` cookie. The cookie value is the
# user's UUID — signing keeps it tamper-proof. Generate with:
#   openssl rand -hex 32
# If unset, the server uses a hardcoded fallback — fine for local dev,
# DEFINITELY change in production.
SESSION_SECRET=replace-with-a-long-random-string

# ── Local dev ─────────────────────────────────────────────────────────────
# Market Buzz Kids runs on 3199 locally so it doesn't collide with a3l-books
# on 3101. Override if you need to.
PORT=3199

# ── Existing (used by digest generation; required only to run /generate) ──
# FMP_API_KEY=
# ANTHROPIC_API_KEY=
# ADMIN_KEY=
